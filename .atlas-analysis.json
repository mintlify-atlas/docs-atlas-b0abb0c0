  "keyFeatures": [
    "Download YouTube videos in MP4 format at various quality levels (up to 4K/60fps)",
    "Download audio-only as MP3 from any YouTube video",
    "Download entire YouTube playlists as video or audio in batch",
    "Parallel downloads with up to 3 concurrent downloads",
    "Built-in FFmpeg integration for video/audio muxing and conversion",
    "MVVM architecture using CommunityToolkit.Mvvm",
    "WinUI 3 modern Windows interface with light/dark/system theme support",
    "Configurable default download path and save location prompts",
    "Download queue with progress tracking, pause, cancel, and retry support",
    "Available via installer (.exe) or Scoop package manager"
  ],
  "publicApiSurface": [
    "YoutubeService.GetVideoAsync(string videoUrl, CancellationToken token)",
    "YoutubeService.GetPlaylistAsync(string playlistUrl, CancellationToken token)",
    "YoutubeService.GetPlaylistVideosAsync(string playlistId, CancellationToken token)",
    "YoutubeService.DownloadVideoAsync(StreamManifest, StreamOption, string, IProgress<double>, CancellationToken)",
    "YoutubeService.DownloadAudioAsync(StreamManifest, string, IProgress<double>, CancellationToken)",
    "DownloadsService.EnqueueDownloadable(IDownloadable downloadable)",
    "SettingsService.Save(AppSettings settings)",
    "SettingsService.Current (AppSettings)",
    "DownloadType enum: Video, Audio",
    "MediaFormat enum: Mp4, Mp3",
